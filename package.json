{
  "name": "protect-the-651",
  "version": "0.0.0-semantically-released",
  "license": "MIT",
  "author": {
    "name": "Nichole Mattera",
    "url": "https://nicholemattera.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicholemattera/protect-the-651.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc & vite build",
    "dev": "vite",
    "format": "oxfmt --check './**/*.{html,css,js,ts,yml,json,md}'",
    "format:fix": "oxfmt './**/*.{html,css,js,ts,yml,json,md}'",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/open-sans": "^5.2.7",
    "@fontsource/anton": "^5.2.7",
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.2"
  },
  "private": true,
  "lint-staged": {
    "./**/*.{html,css,js,ts,yml,json,md}": "oxfmt --no-error-on-unmatched-pattern",
    "./**/*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "releaseRules": [
            {
              "breaking": true,
              "release": "major"
            },
            {
              "revert": true,
              "release": "patch"
            },
            {
              "type": "feat",
              "release": "minor"
            },
            {
              "type": "perf",
              "release": "minor"
            },
            {
              "type": "fix",
              "release": "patch"
            },
            {
              "type": "refactor",
              "release": "patch"
            }
          ]
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  }
}
